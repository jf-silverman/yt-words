# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Required: Anthropic API key (from console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Required for --email-mode smtp:
# Gmail App Password (NOT your regular Gmail password)
# Enable 2FA on your Google account, then:
# Google Account → Security → 2-Step Verification → App Passwords → generate one
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Required for Overcast timestamp links (deep-links into episodes by section):
# Log into overcast.fm with these credentials to fetch Overcast episode IDs.
# If omitted, section links fall back to YouTube timestamps.
OVERCAST_EMAIL=you@example.com
OVERCAST_PASSWORD=yourpassword

# Optional: override sender/recipient (defaults to joelfsilverman@gmail.com)
# GMAIL_FROM=joelfsilverman@gmail.com
# GMAIL_TO=joelfsilverman@gmail.com
